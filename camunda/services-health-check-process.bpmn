<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    id="Definitions_1"
    targetNamespace="http://bpmn.io/schema/bpmn"
    xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd">

	<bpmn:process id="services-health-check-process" name="Services Health Check Process"
	              isExecutable="true"
	              camunda:historyTimeToLive="P30D">

		<bpmn:startEvent id="StartEvent_1">
			<bpmn:outgoing>Flow_1</bpmn:outgoing>
		</bpmn:startEvent>

		<bpmn:parallelGateway id="ParallelStart" name="Start Parallel Checks">
			<bpmn:incoming>Flow_1</bpmn:incoming>
			<bpmn:outgoing>Flow_ToBuilder</bpmn:outgoing>
			<bpmn:outgoing>Flow_ToPayment</bpmn:outgoing>
		</bpmn:parallelGateway>

		<bpmn:serviceTask id="CheckBuilderHealth" name="Check Builder Health"
						  camunda:type="external"
						  camunda:topic="check-builder-health">
			<bpmn:incoming>Flow_ToBuilder</bpmn:incoming>
			<bpmn:outgoing>Flow_FromBuilder</bpmn:outgoing>
		</bpmn:serviceTask>

		<bpmn:serviceTask id="CheckPaymentHealth" name="Check Payment Health"
						  camunda:type="external"
						  camunda:topic="check-payment-health">
			<bpmn:incoming>Flow_ToPayment</bpmn:incoming>
			<bpmn:outgoing>Flow_FromPayment</bpmn:outgoing>
		</bpmn:serviceTask>

		<bpmn:parallelGateway id="ParallelEnd" name="Sync Results">
			<bpmn:incoming>Flow_FromBuilder</bpmn:incoming>
			<bpmn:incoming>Flow_FromPayment</bpmn:incoming>
			<bpmn:outgoing>Flow_ToEvaluation</bpmn:outgoing>
		</bpmn:parallelGateway>

		<bpmn:exclusiveGateway id="EvaluateResults" name="Evaluate Health Status">
			<bpmn:incoming>Flow_ToEvaluation</bpmn:incoming>
			<bpmn:outgoing>Flow_AllHealthy</bpmn:outgoing>
			<bpmn:outgoing>Flow_SomeUnhealthy</bpmn:outgoing>
		</bpmn:exclusiveGateway>

		<bpmn:serviceTask id="LogHealthyResult" name="Log Healthy Status"
						  camunda:type="external"
						  camunda:topic="log-healthy-result">
			<bpmn:incoming>Flow_AllHealthy</bpmn:incoming>
			<bpmn:outgoing>Flow_ToEndHealthy</bpmn:outgoing>
		</bpmn:serviceTask>

		<bpmn:serviceTask id="HandleUnhealthyResult" name="Handle Unhealthy Status"
						  camunda:type="external"
						  camunda:topic="handle-unhealthy-result">
			<bpmn:incoming>Flow_SomeUnhealthy</bpmn:incoming>
			<bpmn:outgoing>Flow_ToEndUnhealthy</bpmn:outgoing>
		</bpmn:serviceTask>

		<bpmn:endEvent id="EndEvent_Healthy">
			<bpmn:incoming>Flow_ToEndHealthy</bpmn:incoming>
		</bpmn:endEvent>

		<bpmn:endEvent id="EndEvent_Unhealthy">
			<bpmn:incoming>Flow_ToEndUnhealthy</bpmn:incoming>
		</bpmn:endEvent>

		<bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="ParallelStart"/>
		<bpmn:sequenceFlow id="Flow_ToBuilder" sourceRef="ParallelStart" targetRef="CheckBuilderHealth"/>
		<bpmn:sequenceFlow id="Flow_ToPayment" sourceRef="ParallelStart" targetRef="CheckPaymentHealth"/>
		<bpmn:sequenceFlow id="Flow_FromBuilder" sourceRef="CheckBuilderHealth" targetRef="ParallelEnd"/>
		<bpmn:sequenceFlow id="Flow_FromPayment" sourceRef="CheckPaymentHealth" targetRef="ParallelEnd"/>
		<bpmn:sequenceFlow id="Flow_ToEvaluation" sourceRef="ParallelEnd" targetRef="EvaluateResults"/>

		<bpmn:sequenceFlow id="Flow_AllHealthy" sourceRef="EvaluateResults" targetRef="LogHealthyResult">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
				<![CDATA[${builderHealthy == true and paymentHealthy == true}]]>
			</bpmn:conditionExpression>
		</bpmn:sequenceFlow>

		<bpmn:sequenceFlow id="Flow_SomeUnhealthy" sourceRef="EvaluateResults" targetRef="HandleUnhealthyResult">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
				<![CDATA[${builderHealthy == false or paymentHealthy == false}]]>
			</bpmn:conditionExpression>
		</bpmn:sequenceFlow>

		<bpmn:sequenceFlow id="Flow_ToEndHealthy" sourceRef="LogHealthyResult" targetRef="EndEvent_Healthy"/>
		<bpmn:sequenceFlow id="Flow_ToEndUnhealthy" sourceRef="HandleUnhealthyResult" targetRef="EndEvent_Unhealthy"/>

	</bpmn:process>

	<bpmndi:BPMNDiagram id="BPMNDiagram_1">
		<bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="services-health-check-process">

			<bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
				<dc:Bounds x="173" y="102" width="36" height="36" />
			</bpmndi:BPMNShape>

			<bpmndi:BPMNShape id="ParallelStart_di" bpmnElement="ParallelStart">
				<dc:Bounds x="250" y="95" width="50" height="50" />
			</bpmndi:BPMNShape>

			<bpmndi:BPMNShape id="CheckBuilderHealth_di" bpmnElement="CheckBuilderHealth">
				<dc:Bounds x="350" y="50" width="100" height="80" />
			</bpmndi:BPMNShape>

			<bpmndi:BPMNShape id="CheckPaymentHealth_di" bpmnElement="CheckPaymentHealth">
				<dc:Bounds x="350" y="150" width="100" height="80" />
			</bpmndi:BPMNShape>

			<bpmndi:BPMNShape id="ParallelEnd_di" bpmnElement="ParallelEnd">
				<dc:Bounds x="500" y="95" width="50" height="50" />
			</bpmndi:BPMNShape>

			<bpmndi:BPMNShape id="EvaluateResults_di" bpmnElement="EvaluateResults">
				<dc:Bounds x="600" y="95" width="50" height="50" />
			</bpmndi:BPMNShape>

			<bpmndi:BPMNShape id="EndEvent_Healthy_di" bpmnElement="EndEvent_Healthy">
				<dc:Bounds x="750" y="50" width="36" height="36" />
			</bpmndi:BPMNShape>

			<bpmndi:BPMNShape id="EndEvent_Unhealthy_di" bpmnElement="EndEvent_Unhealthy">
				<dc:Bounds x="750" y="150" width="36" height="36" />
			</bpmndi:BPMNShape>

			<bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
				<di:waypoint x="209" y="120" />
				<di:waypoint x="250" y="120" />
			</bpmndi:BPMNEdge>

			<bpmndi:BPMNEdge id="Flow_ToBuilder_di" bpmnElement="Flow_ToBuilder">
				<di:waypoint x="275" y="95" />
				<di:waypoint x="275" y="90" />
				<di:waypoint x="350" y="90" />
			</bpmndi:BPMNEdge>

			<bpmndi:BPMNEdge id="Flow_ToPayment_di" bpmnElement="Flow_ToPayment">
				<di:waypoint x="275" y="145" />
				<di:waypoint x="275" y="190" />
				<di:waypoint x="350" y="190" />
			</bpmndi:BPMNEdge>

		</bpmndi:BPMNPlane>
	</bpmndi:BPMNDiagram>
</bpmn:definitions>